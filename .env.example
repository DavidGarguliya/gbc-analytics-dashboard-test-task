# RetailCRM
# Local-only operator variables for import/sync/pipeline. Not required for the
# accepted Vercel dashboard-only deployment shape.
RETAILCRM_BASE_URL=
RETAILCRM_API_KEY=
# Optional: force a specific RetailCRM site code instead of auto-selecting the default/first site
RETAILCRM_SITE_CODE=

# Supabase
# Used by the deployed dashboard server read path and the local operators.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
# Optional: only needed if a browser-safe Supabase client is introduced later.
SUPABASE_ANON_KEY=
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Telegram
# Local-only operator variables for alerts/pipeline. Not required for the
# accepted Vercel dashboard-only deployment shape.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# App
# Optional: set to the local or deployed public URL.
NEXT_PUBLIC_APP_URL=
